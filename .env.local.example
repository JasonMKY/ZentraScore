# ─── Clerk Auth ──────────────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → Your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Required by Clerk middleware when secretKey is propagated in headers.
# Generate once (32+ random chars) and keep stable per environment.
CLERK_ENCRYPTION_KEY=replace_with_long_random_string

# Clerk redirect URLs (leave as-is for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Alchemy (blockchain data) ───────────────────────────────────────────────
# One API key is enough: in Alchemy dashboard, add Ethereum + Arbitrum + Base to the SAME app.
# You do NOT need ALCHEMY_ARBITRUM_KEY / ALCHEMY_BASE_KEY unless you use different apps per chain.
# Paste the full key from Alchemy (usually ~32+ characters).
ALCHEMY_API_KEY=your_alchemy_api_key_here
# Optional overrides (leave blank to reuse ALCHEMY_API_KEY):
# ALCHEMY_ARBITRUM_KEY=
# ALCHEMY_BASE_KEY=
# If your Alchemy app is Ethereum-only but users pick Arbitrum/Base in the UI, either enable
# those networks on the app OR force reads from mainnet:
# ALCHEMY_SCORE_CHAIN=ethereum
#
# Which chains to merge for one score (default: all three). Example to only use mainnet:
# ALCHEMY_SCORE_CHAINS=ethereum

# ─── Covalent / GoldRush (DeFi protocol data) ────────────────────────────────
# Get from: https://goldrush.dev → Get API Key (free tier = 100 req/day)
COVALENT_API_KEY=cqt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Stripe (payments) ───────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get from: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Stripe Price IDs ─────────────────────────────────────────────────────────
# Create products in Stripe dashboard, copy the price IDs here
STRIPE_PRICE_CONSUMER=price_xxxxxxxxxxxxxxxxxxxxxxxx     # $9/mo
STRIPE_PRICE_PROTOCOL=price_xxxxxxxxxxxxxxxxxxxxxxxx     # $499/mo
STRIPE_PRICE_ANALYTICS=price_xxxxxxxxxxxxxxxxxxxxxxxx    # $299/mo

# ─── Database (Supabase + Prisma) ────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string:
#   • "Transaction pooler" (port 6543) → DATABASE_URL  (Vercel / app runtime)
#   • "Session mode" or direct URI (port 5432) → DIRECT_URL  (migrations & db push)
# If a param like ?pgbouncer=true appears on the pooler URL, keep it on DATABASE_URL only.
# Local Docker Postgres: use the same URL for both variables.
# Prisma CLI (`db push`, `migrate`) reads `.env` by default — copy the same two lines there or use `dotenv-cli`.
# Next.js: `.env.development` / `.env.development.local` load AFTER `.env.local` and override the same keys.
# If the dashboard tries localhost:5432, delete DATABASE_URL from those files or point them at Supabase.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].supabase.co:5432/postgres

# ─── Redis (score caching) ────────────────────────────────────────────────────
# Use Upstash for a free hosted Redis, or run locally with `docker run -p 6379:6379 redis`
REDIS_URL=redis://localhost:6379

# ─── Contact form (mailto support@zentrascore.com) ────────────────────────────
# Default recipient is support@zentrascore.com — override if needed:
# CONTACT_SUPPORT_EMAIL=support@zentrascore.com
#
# Option A — Resend (recommended): https://resend.com → API Keys
# Verify your sending domain in Resend, then set FROM to an address on that domain.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL="ZentraScore <noreply@zentrascore.io>"
#
# Option B — SMTP (Gmail, SendGrid SMTP, etc.) if you prefer not to use Resend:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="ZentraScore <noreply@zentrascore.io>"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
